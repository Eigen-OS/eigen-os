          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "PermissionDenied": {
        "description": "PERMISSION_DENIED",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "IdempotencyConflict": {
        "description": "FAILED_PRECONDITION",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "PayloadLimitExceeded": {
        "description": "RESOURCE_EXHAUSTED",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "NotFound": {
        "description": "NOT_FOUND",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "Internal": {
        "description": "INTERNAL",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      },
      "Unavailable": {
        "description": "UNAVAILABLE",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/CanonicalErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "CanonicalErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "message",
              "details"
            ],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "INVALID_ARGUMENT",
                  "UNAUTHENTICATED",
                  "PERMISSION_DENIED",
                  "RESOURCE_EXHAUSTED",
                  "ALREADY_EXISTS",
                  "FAILED_PRECONDITION",
                  "INTERNAL",
                  "UNAVAILABLE",
                  "DEADLINE_EXCEEDED",
                  "CANCELLED",
                  "NOT_FOUND"
                ]
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    },
                    "domain": {
                      "type": "string"
                    },
                    "retryable": {
                      "type": "string",
                      "enum": [
                        "true",
                        "false"
                      ]
                    },
                    "field": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "resource_type": {
                      "type": "string"
                    },
                    "resource_name": {
                      "type": "string"
                    },
                    "subject": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "trace": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "request_id": {
                    "type": "string"
                  },
                  "trace_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "x-canonical-detail-shapes": [
          "google.rpc.BadRequest",
          "google.rpc.ErrorInfo",
          "google.rpc.PreconditionFailure",
          "google.rpc.QuotaFailure",
          "google.rpc.ResourceInfo",
          "google.rpc.RetryInfo",
          "google.rpc.RequestInfo"
        ]
      },
      "BenchmarkRunRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idempotency_key",
          "config"
        ],
        "properties": {
          "idempotency_key": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "config": {
            "type": "object",
            "minProperties": 1,
            "required": [
              "dataset",
              "backend",
              "seed"
            ],
            "properties": {
              "dataset": {
                "type": "string",
                "minLength": 1
              },
              "dataset_version": {
                "type": "string",
                "minLength": 1
              },
              "backend": {
                "type": "string",
                "minLength": 1
              },
              "seed": {
                "type": "integer"
              }
            },
            "additionalProperties": true
          }
        },
        "x-canonical-request-hash": {
          "algorithm": "sha256",
          "source": "canonical_json(benchmark run request body)",
          "collision_policy": "same idempotency key + identical canonical payload returns original response",
          "conflict_policy": "same idempotency key + different canonical payload returns FAILED_PRECONDITION"
        }
      },
      "BenchmarkRunResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "api_version",
          "run",
          "snapshot",
          "trace"
        ],
        "properties": {
          "api_version": {
            "type": "string"
          },
          "run": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "run_id",
              "state",
              "state_contract_version",
              "parent_run_id",
              "idempotency_key"
            ],
            "properties": {
              "run_id": {
                "type": "string"
              },
              "state": {
                "type": "string",
                "enum": [
                  "PENDING",
                  "COMPILING",
                  "QUEUED",
                  "RUNNING",
                  "DONE",
                  "ERROR",
                  "CANCELED",
                  "TIMEOUT"
                ]
              },
              "state_contract_version": {
                "type": "string"
              },
              "parent_run_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "idempotency_key": {
                "type": "string"
              }
            }
          },
          "snapshot": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "contract_version",
              "snapshot_version",
              "history_entry_version",
              "run_id",
              "request_hash",
              "created_at",
              "payload"
            ],
            "properties": {
              "contract_version": {
                "type": "string"
              },
              "snapshot_version": {
                "type": "string"
              },
              "history_entry_version": {
                "type": "string"
              },
              "run_id": {
                "type": "string"
              },
              "request_hash": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "payload": {
                "type": "string"
              }
            }
          },
          "trace": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "trace_id",
              "correlation_id"
            ],
            "properties": {
              "trace_id": {
                "type": "string"
              },
              "correlation_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "ExplainBackendSelectionRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "request_version",
          "response_version",
          "decision_id"
        ],
        "properties": {
          "request_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "response_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "decision_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "include_rejected_candidates": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "ExplainBackendSelectionResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "explain_contract_version",
          "request_version",
          "response_version",
          "scoring_contract_version",
          "profile_schema_version",
          "profile_version",
          "decision_id",
          "job_id",
          "scheduler_trace_id",
          "selected_backend_id",
          "decision_timestamp",
          "tie_break_trace",
          "candidate_scores",
          "factor_contributions",
          "confidence",
          "provenance"
        ],
        "properties": {
          "explain_contract_version": {
            "type": "string"
          },
          "request_version": {
            "type": "string"
          },
          "response_version": {
            "type": "string"
          },
          "scoring_contract_version": {
            "type": "string"
          },
          "profile_schema_version": {
            "type": "string"
          },
          "profile_version": {
            "type": "string"
          },
          "decision_id": {
            "type": "string"
          },
          "job_id": {
            "type": "string"
          },
          "scheduler_trace_id": {
            "type": "string"
          },
          "selected_backend_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "decision_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "tie_break_trace": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "candidate_scores": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CandidateScore"
            }
          },
          "factor_contributions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FactorContribution"
            }
          },
          "confidence": {
            "$ref": "#/components/schemas/Confidence"
          },
          "provenance": {
            "$ref": "#/components/schemas/ExplainProvenance"
          }
        }
      },
      "CandidateScore": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "backend_id",
          "score_millis",
          "eligible",
          "ineligibility_reason",
          "estimated_runtime_ms",
          "estimated_queue_delay_ms",
          "predicted_error_rate",
          "feature_contributions"
        ],
        "properties": {
          "backend_id": {
            "type": "string"
          },
          "score_millis": {
            "type": "integer"
          },
          "eligible": {
            "type": "boolean"
          },
          "ineligibility_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "estimated_runtime_ms": {
            "type": "integer"
          },
          "estimated_queue_delay_ms": {
            "type": "integer"
          },
          "predicted_error_rate": {
            "type": "number"
          },
          "feature_contributions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeatureContribution"
            }
          }
        }
      },
      "FeatureContribution": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "feature",
          "contribution_millis"
        ],
        "properties": {
          "feature": {
            "type": "string"
          },
          "contribution_millis": {
            "type": "integer"
          }
        }
      },
      "FactorContribution": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "backend_id",
          "factor",
          "contribution_millis"
        ],
        "properties": {
          "backend_id": {
            "type": "string"
          },
          "factor": {
            "type": "string"
          },
          "contribution_millis": {
            "type": "integer"
          }
        }
      },
      "Confidence": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "score_margin_millis",
          "selected_score_millis",
          "runner_up_score_millis",
          "confidence"
        ],
        "properties": {
          "score_margin_millis": {
            "type": "integer"
          },
          "selected_score_millis": {
            "type": "integer"
          },
          "runner_up_score_millis": {
            "type": "integer"
          },
          "confidence": {
            "type": "number"
          }
        }
      },
      "ExplainProvenance": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scheduler_version",
          "gnn_model_version",
          "policy_version",
          "driver_snapshot_version"
        ],
        "properties": {
          "scheduler_version": {
            "type": "string"
          },
          "gnn_model_version": {
            "type": "string"
          },
          "policy_version": {
            "type": "string"
          },
          "driver_snapshot_version": {
            "type": "string"
          }
        }
      }
    }
  }
