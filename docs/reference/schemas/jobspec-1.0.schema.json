{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eigen-os.org/schemas/jobspec-1.0.schema.json",
  "title": "Eigen OS JobSpec 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "eigen.os/v1" },
    "kind": { "const": "QuantumJob" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[a-zA-Z0-9._-]+$" },
        "namespace": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "program"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "priority": { "type": "integer", "minimum": 0, "maximum": 100, "default": 50 },
        "entrypoint": { "type": "string", "minLength": 1, "default": "main" },
        "program": {
          "type": "object",
          "additionalProperties": false,
          "oneOf": [{ "required": ["path"] }, { "required": ["source"] }],
          "properties": {
            "path": { "type": "string", "minLength": 1, "not": { "pattern": "(^/|(^|/)\\.\\.(/|$))" } },
            "source": { "type": "string", "minLength": 1 }
          }
        },
        "compiler": { "type": "object", "additionalProperties": { "type": "string" } },
        "compiler_options": { "type": "object", "additionalProperties": { "type": "string" } },
        "metadata": { "type": "object", "additionalProperties": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scheduling": { "type": "object" },
    "security": { "type": "object" },
    "observability": { "type": "object" },
    "runtime": { "type": "object" },
    "resources": { "type": "object" },
    "artifacts": { "type": "object" }
  }
}
