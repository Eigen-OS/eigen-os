{
  "title": "Eigen Intelligent Runtime \u2014 Decisions, Fallbacks, Explain SLO",
  "uid": "eigen-intelligent-runtime-v10",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Decision Throughput by Policy Mode (5m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "increase(eigen_runtime_decisions_total{policy_mode=\"latency\"}[5m])",
          "legendFormat": "latency / 5m"
        },
        {
          "expr": "increase(eigen_runtime_decisions_total{policy_mode=\"throughput\"}[5m])",
          "legendFormat": "throughput / 5m"
        },
        {
          "expr": "increase(eigen_runtime_decisions_total{policy_mode=\"cost\"}[5m])",
          "legendFormat": "cost / 5m"
        },
        {
          "expr": "increase(eigen_runtime_decisions_total{policy_mode=\"balanced\"}[5m])",
          "legendFormat": "balanced / 5m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Scoring Latency p95 (ms)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(eigen_runtime_scoring_latency_ms_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 150
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Scoring Failures & Explain Errors (10m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "increase(eigen_runtime_scoring_failures_total[10m])",
          "legendFormat": "scoring failures / 10m"
        },
        {
          "expr": "increase(eigen_runtime_explain_errors_total[10m])",
          "legendFormat": "explain errors / 10m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Fallback Rate and Frequency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "increase(eigen_runtime_fallback_total[15m])",
          "legendFormat": "fallback count / 15m"
        },
        {
          "expr": "100 * increase(eigen_runtime_fallback_total[15m]) / clamp_min(increase(eigen_runtime_decisions_total[15m]), 1)",
          "legendFormat": "fallback rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Explain p95 Latency by Level (ms)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (level, le) (rate(eigen_runtime_explain_latency_ms_bucket[5m])))",
          "legendFormat": "L{{level}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Policy Branch Drift Indicator (30m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "100 * stddev(increase(eigen_runtime_policy_branch_total[30m])) / clamp_min(avg(increase(eigen_runtime_policy_branch_total[30m])), 1)",
          "legendFormat": "branch variability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 25
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Observability Contract Version",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "max by (contract_version) (eigen_runtime_contract_info)",
          "legendFormat": "{{contract_version}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      }
      },
    {
      "type": "timeseries",
      "title": "Optimizer Candidate Traces (15m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "increase(eigen_runtime_optimizer_candidate_traces_total[15m])",
          "legendFormat": "candidate traces / 15m"
        },
        {
          "expr": "increase(eigen_runtime_optimizer_candidate_traces_total{result=\"selected\"}[15m])",
          "legendFormat": "selected / 15m"
        },
        {
          "expr": "increase(eigen_runtime_optimizer_candidate_traces_total{result=\"fallback\"}[15m])",
          "legendFormat": "fallback / 15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Optimizer Confidence and Fallbacks (15m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_runtime_optimizer_last_confidence_score",
          "legendFormat": "last confidence"
        },
        {
          "expr": "increase(eigen_runtime_optimizer_fallbacks_total[15m])",
          "legendFormat": "fallbacks / 15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 0.6
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Optimizer Trace Continuity Handoffs (15m)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "increase(eigen_runtime_optimizer_trace_handoff_total{handoff=\"kernel_to_optimizer\"}[15m])",
          "legendFormat": "kernel \u2192 optimizer"
        },
        {
          "expr": "increase(eigen_runtime_optimizer_trace_handoff_total{handoff=\"optimizer_to_downstream\"}[15m])",
          "legendFormat": "optimizer \u2192 downstream"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
