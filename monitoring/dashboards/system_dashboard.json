{
  "title": "Eigen System \u2014 API, Kernel, QFS and Traces",
  "uid": "eigen-system",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "API Requests / sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "rate(eigen_api_requests_total[5m])",
          "legendFormat": "requests/s"
        },
        {
          "expr": "rate(eigen_api_job_submissions_total[5m])",
          "legendFormat": "job submissions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "API Latency P95/P99",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(eigen_api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(eigen_api_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Kernel Active Jobs",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_kernel_active_jobs",
          "legendFormat": "Kernel Active Jobs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Kernel Stage Latency",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(eigen_kernel_stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "QFS Artifact Activity",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "rate(eigen_qfs_artifact_store_total[5m])",
          "legendFormat": "store"
        },
        {
          "expr": "rate(eigen_qfs_artifact_load_total[5m])",
          "legendFormat": "load"
        },
        {
          "expr": "rate(eigen_qfs_replay_bundles_total[5m])",
          "legendFormat": "replay"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Contract Coverage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_observability_contract_info",
          "legendFormat": "observability"
        },
        {
          "expr": "eigen_system_api_contract_info",
          "legendFormat": "system-api"
        },
        {
          "expr": "eigen_kernel_contract_info",
          "legendFormat": "kernel"
        },
        {
          "expr": "eigen_qfs_contract_info",
          "legendFormat": "qfs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    }
  ]
}
