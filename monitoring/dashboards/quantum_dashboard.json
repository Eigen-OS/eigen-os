{
  "title": "Eigen Quantum \u2014 Fidelity, Queue and Calibration",
  "uid": "eigen-quantum",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Quantum Queue Depth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_quantum_queue_depth",
          "legendFormat": "depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Gate / Readout Fidelity",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_quantum_gate_fidelity",
          "legendFormat": "gate"
        },
        {
          "expr": "eigen_quantum_readout_fidelity",
          "legendFormat": "readout"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "Calibration Age (s)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_quantum_calibration_age_seconds",
          "legendFormat": "Calibration Age (s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 86400
              },
              {
                "color": "red",
                "value": 604800
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "timeseries",
      "title": "T1 / T2 (s)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "eigen_quantum_t1_seconds",
          "legendFormat": "T1"
        },
        {
          "expr": "eigen_quantum_t2_seconds",
          "legendFormat": "T2"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Topology Degradation",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "targets": [
        {
          "expr": "rate(eigen_quantum_topology_degradation_total[5m])",
          "legendFormat": "degradation/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    }
  ]
}
