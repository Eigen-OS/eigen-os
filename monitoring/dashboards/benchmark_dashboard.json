{
  "title": "Eigen Benchmark — Lifecycle SLO",
  "uid": "eigen-benchmark-v10",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Benchmark Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "eigen_bench_queue_depth", "legendFormat": "depth" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" }, { "color": "orange", "value": 50 }, { "color": "red", "value": 150 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Run Duration (p95 approximation)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "eigen_bench_run_duration_seconds", "legendFormat": "duration" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" }, { "color": "orange", "value": 300 }, { "color": "red", "value": 900 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Runs Succeeded vs Failed (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "increase(eigen_bench_runs_succeeded_total[15m])", "legendFormat": "succeeded / 15m" },
        { "expr": "increase(eigen_bench_runs_failed_total[15m])", "legendFormat": "failed / 15m" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Ingestion Failures (10m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "increase(eigen_bench_ingestion_failures_total[10m])", "legendFormat": "failures / 10m" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Stalled Runs",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "eigen_bench_stalled_runs", "legendFormat": "stalled" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green" }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Observability Contract Version",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "eigen_bench_contract_info", "legendFormat": "contract" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    }
  ]
}
