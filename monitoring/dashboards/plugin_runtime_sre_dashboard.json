{
  "title": "Eigen Plugin Runtime — Health, Trust, and Sandbox SRE",
  "uid": "eigen-plugin-runtime-sre-v1",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "Plugin Inventory (Installed by Type)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        { "expr": "sum by (plugin_type) (eigen_plugin_inventory_total)", "legendFormat": "{{plugin_type}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Plugin Activation Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(eigen_plugin_activation_latency_ms_bucket[5m])))",
          "legendFormat": "activation p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "orange", "value": 400 },
              { "color": "red", "value": 700 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Plugin Startup Critical Path Duration p95 (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(eigen_plugin_startup_critical_path_ms_bucket[5m])))",
          "legendFormat": "startup critical-path p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "orange", "value": 1200 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Discovery and Activation Failures (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        { "expr": "increase(eigen_plugin_discovery_failures_total[15m])", "legendFormat": "discovery / 15m" },
        { "expr": "increase(eigen_plugin_activation_failures_total[15m])", "legendFormat": "activation / 15m" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Compatibility / Signature / Sandbox Rejects (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        { "expr": "increase(eigen_plugin_compatibility_rejects_total[15m])", "legendFormat": "compatibility rejects / 15m" },
        { "expr": "increase(eigen_plugin_signature_rejects_total[15m])", "legendFormat": "signature rejects / 15m" },
        { "expr": "increase(eigen_plugin_sandbox_rejects_total[15m])", "legendFormat": "sandbox rejects / 15m" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top Rejection Reasons (15m)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "topk(10, sum by (reason_code) (increase(eigen_plugin_rejections_total[15m])))",
          "legendFormat": "{{reason_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Plugin Failure Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "100 * increase(eigen_plugin_failures_total[15m]) / clamp_min(increase(eigen_plugin_attempts_total[15m]), 1)",
          "legendFormat": "failure rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green" },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Startup SLO Breach Events (10m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "increase(eigen_plugin_startup_slo_breaches_total[10m])",
          "legendFormat": "startup SLO breaches / 10m"
        }
      ]
    }
  ]
}
