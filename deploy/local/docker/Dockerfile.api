FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY src/services/system-api /app/src/services/system-api
COPY proto /app/proto

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e /app/src/services/system-api

EXPOSE 50051 9090

CMD ["system-api"]