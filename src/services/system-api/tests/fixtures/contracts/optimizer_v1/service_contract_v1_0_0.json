{
  "contract": "optimizer_service",
  "version": "1.0.0",
  "request": {
    "required_fields": [
      "envelope.contract_version",
      "request_id",
      "input_aqo",
      "topology.topology_ref",
      "objective.preset",
      "deterministic_seed",
      "graph_encoding.canonical_sha256",
      "policy.mode"
    ],
    "deterministic_defaults": {
      "candidate_budget": 1,
      "timeout_ms": 100,
      "trace_context": {}
    },
    "graph_encoding": {
      "encoding_version": "aqo-graph-v1",
      "canonical_format": "aqo-json",
      "canonical_graph": {
        "nodes": [
          {
            "id": "q0",
            "type": "logical_qubit",
            "features": {
              "degree": 2,
              "readout_error": 0.001
            }
          },
          {
            "id": "q1",
            "type": "logical_qubit",
            "features": {
              "degree": 1,
              "readout_error": 0.002
            }
          }
        ],
        "edges": [
          {
            "id": "q0-q1",
            "source": "q0",
            "target": "q1",
            "coupling": 1.0
          }
        ]
      },
      "canonical_sha256": "2f78f4f9355f2ed2f81b9aa2fdaacb3392dae722d4bd751eafb2cf7e3eff562f",
      "round_trip_stability": true
    },
    "ranking_semantics": {
      "sort_order": [
        "score.total_score desc",
        "confidence desc",
        "candidate_id asc"
      ],
      "selected_candidate_is_first": true
    },
    "policy": {
      "mode": "deterministic",
      "minimum_confidence": 0.8,
      "max_depth": 12,
      "max_swaps": 3,
      "forbidden_qubits": [
        "q5"
      ],
      "forbidden_edges": [
        "q2-q3"
      ]
    }
  },
  "response": {
    "required_fields": [
      "request_id",
      "candidates",
      "selected_candidate_id",
      "model_version",
      "fallback_used",
      "fallback_reason_code",
      "deterministic_seed",
      "optimizer_latency_ms",
      "confidence_score",
      "explanation_ref",
      "optimizer_digest"
    ],
    "fallback_contract": {
      "fallback_used": true,
      "requires_fallback_reason": true,
      "requires_fallback_reason_code": true
    },
    "ranking": {
      "selected_candidate_id": "candidate-0",
      "ordered_candidate_ids": [
        "candidate-0",
        "candidate-1"
      ],
      "tie_breakers": [
        "score.total_score",
        "confidence",
        "candidate_id"
      ]
    },
    "confidence": {
      "score": 0.92,
